<Rose::Layout::Page as |page|>

  <page.breadcrumbs>
    <Breadcrumbs::Container />
  </page.breadcrumbs>

  <page.header>
    {{#if @model.currentScope.isGlobal}}
      <Hds::Text::Display @tag='h2' @size='400' @weight='bold'>
        {{t 'resources.org.title_plural'}}
        <DocLink @doc='org' />
      </Hds::Text::Display>
      {{#if @model.doScopesExist}}
        <Hds::Text::Body @tag='p' @size='300' class='p'>
          {{t 'resources.org.description'}}
        </Hds::Text::Body>
      {{/if}}
    {{else if @model.currentScope.isOrg}}
      <Hds::Text::Display @tag='h2' @size='400' @weight='bold'>
        {{t 'resources.project.title_plural'}}
        <DocLink @doc='project' />
      </Hds::Text::Display>
      {{#if @model.doScopesExist}}
        <Hds::Text::Body @tag='p' @size='300' class='p'>
          {{t 'resources.project.description'}}
        </Hds::Text::Body>
      {{/if}}
    {{/if}}
  </page.header>

  <page.actions>
    {{#if (can 'create model' @model.currentScope collection='scopes')}}
      {{#if @model.doScopesExist}}
        <Hds::Button
          @route='scopes.scope.scopes.new'
          @text={{t
            (if
              @model.currentScope.isGlobal
              'resources.org.titles.new'
              'resources.project.titles.new'
            )
          }}
        />
      {{/if}}
    {{/if}}
  </page.actions>

  <page.body class='search-filtering'>

    {{#if @model.doScopesExist}}
      <Hds::SegmentedGroup as |S|>
        <S.TextInput
          @value={{this.search}}
          @type='search'
          placeholder={{t 'actions.search'}}
          aria-label={{t 'actions.search'}}
          {{on 'input' this.handleSearchInput}}
        />
      </Hds::SegmentedGroup>
      {{#if @model.subScopes}}
        <Hds::Table
          @valign='middle'
          @sortBy={{this.sortAttribute}}
          @sortOrder={{this.sortDirection}}
          @onSort={{this.sortBy}}
        >
          <:head as |H|>
            <H.Tr>
              <H.ThSort
                @onClickSort={{fn H.setSortBy 'name'}}
                @sortOrder={{if (eq 'name' H.sortBy) H.sortOrder}}
              >
                {{t 'form.name.label'}}
              </H.ThSort>
              <H.ThSort
                @onClickSort={{fn H.setSortBy 'id'}}
                @sortOrder={{if (eq 'id' H.sortBy) H.sortOrder}}
              >
                {{t 'form.id.label'}}
              </H.ThSort>
            </H.Tr>
          </:head>
          <:body as |B|>
            {{#each @model.subScopes as |data|}}
              <B.Tr data-test-scopes-table-row={{data.id}}>
                <B.Td>
                  {{#if (can 'read model' data)}}
                    <LinkTo @route='scopes.scope' @model={{data.id}}>
                      {{data.displayName}}
                    </LinkTo>
                  {{else}}
                    <Hds::Text::Body @tag='p'>
                      {{data.displayName}}
                    </Hds::Text::Body>
                  {{/if}}
                  <Hds::Text::Body @tag='p'>
                    {{data.description}}
                  </Hds::Text::Body>
                </B.Td>
                <B.Td>
                  <Hds::Copy::Snippet
                    @textToCopy={{data.id}}
                    @color='secondary'
                  />
                </B.Td>
              </B.Tr>
            {{/each}}
          </:body>
        </Hds::Table>
        <Rose::Pagination
          @totalItems={{@model.totalItems}}
          @currentPage={{this.page}}
          @currentPageSize={{this.pageSize}}
        />
      {{else}}
        <Hds::ApplicationState data-test-no-scope-results as |A|>
          <A.Header @title={{t 'titles.no-results-found'}} />
          <A.Body
            @text={{t
              'descriptions.no-search-results'
              query=this.search
              resource=(t 'resources.scope.title_plural')
            }}
          />
        </Hds::ApplicationState>
      {{/if}}

    {{else}}
      <Hds::ApplicationState as |A|>
        <A.Header
          @title={{t
            (if
              @model.currentScope.isGlobal
              'resources.org.messages.welcome.title'
              'resources.project.messages.welcome.title'
            )
          }}
        />
        <A.Body
          @text={{t
            (if
              @model.currentScope.isGlobal
              'resources.org.description'
              'resources.project.description'
            )
          }}
        />
        {{#if (can 'create model' @model.currentScope collection='scopes')}}
          <A.Footer as |F|>
            <F.LinkStandalone
              @icon='plus-circle'
              @text={{t 'titles.new'}}
              @route='scopes.scope.scopes.new'
            />
          </A.Footer>
        {{/if}}
      </Hds::ApplicationState>
    {{/if}}

  </page.body>

</Rose::Layout::Page>