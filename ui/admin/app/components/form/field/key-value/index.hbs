<Hds::Form::KeyValueInputs
  name={{@name}}
  @data={{@data}}
  @isRequired={{@isRequired}}
  @isOptional={{@isOptional}}
  disabled={{@disabled}}
>
  <:header as |H|>
    <H.Legend>{{@legend}}</H.Legend>
    {{#if @helperText}}
      <H.HelperText>{{@helperText}}</H.HelperText>
    {{/if}}
  </:header>
  <:row as |R|>
    {{yield
      (hash
        Field=R.Field
        DeleteRowButton=R.DeleteRowButton
        rowData=R.rowData
        removeRow=(fn this.handleRemove R.rowData)
        updateRow=(fn this.handleUpdate R.rowData)
        canDelete=this.canDelete
      )
      to='row'
    }}
  </:row>
  <:footer as |F|>
    <F.AddRowButton
      @text={{t 'actions.add'}}
      data-test-add-button
      @onClick={{this.handleAdd}}
    />
    {{#if @errors}}
      <F.Error as |E|>
        {{#each @errors as |error|}}
          <E.Message data-test-error-message>{{error.message}}</E.Message>
        {{/each}}
      </F.Error>
    {{/if}}
  </:footer>
</Hds::Form::KeyValueInputs>