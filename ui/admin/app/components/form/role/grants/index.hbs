<Hds::Layout::Flex as |F|>
  <F.Item @basis='66%'>
    <Hds::CodeBlock class='grant-codeblock' @value={{this.grants}} />
  </F.Item>
</Hds::Layout::Flex>

{{#if (can 'setGrants role' @model)}}
  <Hds::ButtonSet class='margin-top-l' data-test-grants-btns>
    <Hds::Button
      @text={{t 'resources.role.edit-grants.title'}}
      @color='secondary'
      @route='scopes.scope.roles.role.edit-grants'
    />
    <Hds::Button
      @text={{t 'resources.role.grant-templates.actions.add-grant-templates'}}
      @color='secondary'
      @route='scopes.scope.roles.role.add-grant-templates'
    />
  </Hds::ButtonSet>
{{/if}}