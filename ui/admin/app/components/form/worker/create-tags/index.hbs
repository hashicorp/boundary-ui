<Rose::Form
  @onSubmit={{this.save}}
  @cancel={{@cancel}}
  @disabled={{@model.isSaving}}
  @showEditToggle={{false}}
  as |form|
>
  <Form::Field::KeyValue
    @name='api_tags'
    @data={{@apiTags}}
    @onAdd={{fn this.addApiTag (array 'key' 'value')}}
    @onRemove={{this.removeApiTag}}
    @onUpdate={{this.updateApiTag}}
    @disabled={{form.disabled}}
    @isOptional={{true}}
  >
    <:row as |R|>
      <R.Field as |F|>
        <F.TextInput
          data-test-key-input
          @value={{R.rowData.key}}
          {{on 'input' (fn R.updateRow 'key')}}
        />
      </R.Field>
      <R.Field as |F|>
        <F.TextInput
          data-test-value-input
          @value={{R.rowData.value}}
          {{on 'input' (fn R.updateRow 'value')}}
        />
      </R.Field>
      {{#if R.canDelete}}
        <R.DeleteRowButton data-test-delete-button @onClick={{R.removeRow}} />
      {{/if}}
    </:row>
  </Form::Field::KeyValue>

  <form.actions
    @submitText={{t 'actions.save'}}
    @cancelText={{t 'actions.cancel'}}
  />
</Rose::Form>