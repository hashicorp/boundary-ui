{{#if this.isGrantsSchemaUnavailable}}
  <Hds::Text::Body @tag='p' @size='200' @color='faint'>
    {{t 'resources.role.edit-grants.actions.unavailable'}}
  </Hds::Text::Body>
{{else if @currentResourceType}}
  {{#if (gt this.allActions.length 0)}}
    <Hds::Table
      @model={{this.allActions}}
      @columns={{array
        (hash key='name' label=(t 'titles.action'))
        (hash key='description' label=(t 'form.description.label'))
      }}
      @valign='middle'
    >
      <:body as |B|>
        <B.Tr>
          <B.Td>{{B.data.name}}</B.Td>
          <B.Td>{{B.data.description}}</B.Td>
        </B.Tr>
      </:body>
    </Hds::Table>
  {{else}}
    <Hds::Text::Body @tag='p' @size='200' @color='faint'>
      {{t 'resources.role.edit-grants.actions.no-actions'}}
    </Hds::Text::Body>
  {{/if}}
{{else}}
  <Hds::Text::Body @tag='p' @size='200' @color='faint'>
    {{t 'resources.role.edit-grants.actions.no-type-detected'}}
  </Hds::Text::Body>
{{/if}}