{{#if this.actionRows.length}}
  <Hds::Table
    @model={{this.actionRows}}
    @columns={{this.columns}}
    @valign='middle'
    data-test-grant-actions-table
  >
    <:body as |B|>
      <B.Tr data-test-grant-action>
        <B.Td data-test-grant-action-name>{{B.data.name}}</B.Td>
        <B.Td data-test-grant-action-description>{{B.data.description}}</B.Td>
      </B.Tr>
    </:body>
  </Hds::Table>
{{else if this.showNoResourceTypeDetected}}
  <Hds::Alert @type='compact' as |A|>
    <A.Description data-test-grant-actions-no-type-detected>
      {{this.noResourceTypeDetectedLabel}}
    </A.Description>
  </Hds::Alert>
{{else}}
  <Hds::Alert @type='compact' as |A|>
    <A.Description data-test-grant-actions-empty-state>
      {{this.noSuggestionsLabel}}
    </A.Description>
  </Hds::Alert>
{{/if}}